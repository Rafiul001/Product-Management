{
  "name": "product-management",
  "version": "1.0.0",
  "description": "product management server",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev:client": "npm --prefix src/client run dev",
    "dev:server": "nodemon --exec \"tsx --tsconfig tsconfig.server.json\" ./src/server.ts",
    "build:client": "npm --prefix src/client run build",
    "build:server": "tsc -p tsconfig.server.json && tsc-alias -p tsconfig.server.json",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npm run build:server && npm run build:client",
    "start:client": "npm --prefix src/client run preview",
    "start:server": "node dist/server.js",
    "start": "concurrently \"npm run start:server\" \"npm run start:client\""
  },
  "author": "Rafiul2001",
  "license": "ISC",
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.3",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/otp-generator": "^4.0.2",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "otp-generator": "^4.0.1",
    "sslcommerz-lts": "^1.2.0",
    "zod": "^4.3.6"
  }
}
